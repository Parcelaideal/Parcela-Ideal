<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Parcela Ideal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ['Playfair Display', 'serif'],
            body: ['DM Sans', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <style>
    :root {
      --navy: #1E40AF; --navy-dark: #162E80; --navy-light: #3B5FCC;
      --gold: #C9A84C; --bg: #F8FAFC; --card: #fff;
      --text: #0F172A; --muted: #475569; --border: #E2E8F0;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); min-height: 100vh; color: var(--text); overflow-x: hidden; }
    body::before {
      content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 0;
      background-image:
        radial-gradient(circle at 20% 20%, rgba(30,64,175,0.04) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(201,168,76,0.04) 0%, transparent 50%),
        url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%231E40AF' fill-opacity='0.025' fill-rule='evenodd'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E");
    }
    .page-wrapper { position: relative; z-index: 1; }
    .hero-header {
      background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 60%, var(--navy-light) 100%);
      position: relative; overflow: hidden;
    }
    .hero-header::before {
      content: ''; position: absolute; inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.04' fill-rule='evenodd'%3E%3Cpath d='M50 50c0-5.523 4.477-10 10-10s10 4.477 10 10-4.477 10-10 10c0 5.523-4.477 10-10 10s-10-4.477-10-10 4.477-10 10-10zM10 10c0-5.523 4.477-10 10-10s10 4.477 10 10-4.477 10-10 10c0 5.523-4.477 10-10 10S0 25.523 0 20s4.477-10 10-10z'/%3E%3C/g%3E%3C/svg%3E");
    }
    .gold-line { height: 3px; background: linear-gradient(90deg, transparent, var(--gold), transparent); }
    .badge {
      display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px;
      background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2);
      border-radius: 99px; font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
      text-transform: uppercase; color: rgba(255,255,255,0.85);
    }
    .stat-pill {
      display: flex; align-items: center; gap: 8px; padding: 8px 14px;
      background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12); border-radius: 12px;
    }
    .main-card {
      background: var(--card); border-radius: 24px;
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 20px 60px -10px rgba(30,64,175,0.1), 0 0 0 1px rgba(226,232,240,0.8);
    }
    .result-panel {
      background: linear-gradient(135deg, #EFF6FF, #F0F7FF);
      border: 1.5px solid #BFDBFE; border-radius: 16px; position: relative; overflow: hidden;
    }
    .result-panel::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--navy), var(--gold));
    }
    .result-amount {
      font-family: 'Playfair Display', serif; font-weight: 700; letter-spacing: -0.02em; line-height: 1;
      font-size: clamp(28px, 7vw, 48px);
    }
    .calc-bar-wrap { height: 3px; background: #E2E8F0; border-radius: 99px; overflow: hidden; }
    .calc-bar { height: 100%; width: 0%; background: linear-gradient(90deg, var(--navy), var(--gold)); border-radius: 99px; transition: width 0.4s cubic-bezier(0.4,0,0.2,1); }
    .input-label { display: block; font-size: 12px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; }
    .input-wrap { position: relative; }
    .input-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #94A3B8; width: 18px; height: 18px; pointer-events: none; transition: color 0.25s; }
    .input-wrap:focus-within .input-icon { color: var(--navy); }
    .input-field {
      width: 100%; padding: 14px 16px 14px 44px; border: 1.5px solid var(--border);
      border-radius: 12px; font-family: 'DM Sans', sans-serif; font-size: 15px; color: var(--text);
      background: var(--bg); transition: all 0.25s; outline: none; -webkit-appearance: none;
    }
    .input-field:focus { border-color: var(--navy); background: #fff; box-shadow: 0 0 0 4px rgba(30,64,175,0.08); }
    .input-field::placeholder { color: #94A3B8; }
    .currency-prefix { position: absolute; left: 44px; top: 50%; transform: translateY(-50%); font-weight: 600; color: var(--muted); font-size: 14px; pointer-events: none; }
    .has-prefix .input-field { padding-left: 72px; }
    .section-divider {
      display: flex; align-items: center; gap: 12px; color: #94A3B8;
      font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; margin: 8px 0;
    }
    .section-divider::before, .section-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }
    .cta-btn {
      display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%;
      padding: 16px 24px; background: linear-gradient(135deg, #25D366, #128C7E);
      color: white; font-family: 'DM Sans', sans-serif; font-size: 16px; font-weight: 600;
      border: none; border-radius: 14px; cursor: pointer; text-decoration: none;
      box-shadow: 0 4px 20px rgba(37,211,102,0.35); transition: all 0.25s;
    }
    .cta-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(37,211,102,0.45); }
    .cta-btn:active { transform: translateY(0); }
    .disclaimer { font-size: 11px; color: #94A3B8; text-align: center; line-height: 1.5; }
    @keyframes fadeSlideUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
    @keyframes pulseNum { 0%,100%{transform:scale(1);} 50%{transform:scale(1.04);} }
    .fade-up { animation: fadeSlideUp 0.6s ease both; }
    .pulse-once { animation: pulseNum 0.4s ease; }
    .hidden-section { display: none; opacity: 0; }
    @media (max-width:480px) { .main-card { border-radius: 20px; } }
  </style>
</head>
<body>
<div class="page-wrapper">

  <div class="hero-header px-4 pt-10 pb-12">
    <div class="max-w-lg mx-auto text-center">
      <div class="flex justify-center mb-5">
        <span class="badge">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="5" fill="#C9A84C"/></svg>
          Ferramenta Imobili&aacute;ria
        </span>
      </div>
      <h1 class="font-display text-white text-3xl sm:text-4xl font-bold leading-tight mb-3">
        Parcela Ideal
      </h1>
      <p class="text-blue-200 text-sm font-light max-w-xs mx-auto leading-relaxed">
        Descubra sua capacidade estimada de parcela mensal em segundos &mdash; baseado em diretrizes reais de financiamento.
      </p>
      <div class="flex justify-center gap-3 mt-6">
        <div class="stat-pill">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="rgba(255,255,255,0.7)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          <span class="text-white text-xs font-medium">Resultado Imediato</span>
        </div>
        <div class="stat-pill">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="rgba(255,255,255,0.7)" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span class="text-white text-xs font-medium">M&eacute;todo Confi&aacute;vel</span>
        </div>
      </div>
    </div>
  </div>

  <div class="gold-line"></div>

  <div class="max-w-lg mx-auto px-4 -mt-6 pb-12">
    <div class="main-card p-6 sm:p-8 fade-up">

      <div class="result-panel p-5 mb-7">
        <div class="flex items-start justify-between mb-1">
          <p class="text-xs font-semibold uppercase tracking-widest text-blue-500">Capacidade Mensal Est.</p>
          <span id="calcBadge" class="text-xs text-slate-400 font-medium hidden">Calculando...</span>
        </div>
        <div class="calc-bar-wrap mb-3" id="barWrap" style="display:none;"><div class="calc-bar" id="calcBar"></div></div>
        <div class="result-amount" id="resultAmount" style="color:#CBD5E1; font-size:36px;">&mdash;</div>
        <p class="text-xs text-slate-400 mt-2">Baseado na regra dos 30% da renda &middot; Apenas estimativa</p>
      </div>

      <div class="space-y-5">
        <div class="section-divider">Seus Dados</div>
        <div>
          <label class="input-label" for="fullName">Nome Completo</label>
          <div class="input-wrap">
            <svg class="input-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <input type="text" id="fullName" class="input-field" placeholder="Ex: Maria Silva" autocomplete="name"/>
          </div>
        </div>
        <div>
          <label class="input-label" for="whatsapp">N&uacute;mero de WhatsApp</label>
          <div class="input-wrap">
            <svg class="input-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <input type="tel" id="whatsapp" class="input-field" placeholder="Ex: (47) 99133-4270" autocomplete="tel"/>
          </div>
        </div>
        <div class="section-divider">Informa&ccedil;&otilde;es Financeiras</div>
        <div>
          <label class="input-label" for="income">Renda Bruta Mensal</label>
          <div class="input-wrap has-prefix">
            <svg class="input-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="currency-prefix">R$</span>
            <input type="number" id="income" class="input-field" placeholder="0,00" min="0" step="100" inputmode="decimal"/>
          </div>
        </div>
        <div>
          <label class="input-label" for="downPayment">Valor de Entrada</label>
          <div class="input-wrap has-prefix">
            <svg class="input-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
            <span class="currency-prefix">R$</span>
            <input type="number" id="downPayment" class="input-field" placeholder="0,00" min="0" step="500" inputmode="decimal"/>
          </div>
        </div>
      </div>

      <div id="ctaSection" class="hidden-section mt-7">
        <div class="section-divider mb-5">Pronto para dar o pr&oacute;ximo passo?</div>
        <div class="bg-slate-50 border border-slate-200 rounded-2xl p-4 mb-4">
          <div class="flex items-center justify-between mb-2">
            <span class="text-xs text-slate-500 font-medium">Seu Resumo</span>
            <span class="text-xs font-semibold" style="color:var(--navy)">Lead Qualificado &checkmark;</span>
          </div>
          <div class="space-y-1.5">
            <div class="flex justify-between text-sm">
              <span class="text-slate-500">Renda Bruta</span>
              <span class="font-semibold text-slate-800" id="summaryIncome">&mdash;</span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-slate-500">Entrada</span>
              <span class="font-semibold text-slate-800" id="summaryDown">&mdash;</span>
            </div>
            <div class="flex justify-between text-sm border-t border-slate-200 pt-1.5 mt-1.5">
              <span class="text-slate-500 font-medium">Capacidade Mensal</span>
              <span class="font-bold" style="color:var(--navy)" id="summaryResult">&mdash;</span>
            </div>
          </div>
        </div>
        <a href="#" id="ctaBtn" class="cta-btn" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Agendar Consultoria pelo WhatsApp
        </a>
        <p class="disclaimer mt-3">Nosso consultor entrar&aacute; em contato em at&eacute; 24 horas para apresentar as melhores op&ccedil;&otilde;es de im&oacute;veis para voc&ecirc;.</p>
      </div>
      <p class="disclaimer mt-6">Esta simula&ccedil;&atilde;o &eacute; meramente informativa e n&atilde;o representa oferta ou compromisso de financiamento. Os resultados s&atilde;o baseados em diretrizes amplamente utilizadas no mercado imobili&aacute;rio.</p>
    </div>

    <div class="text-center mt-6 pb-2">
      <p class="text-xs text-slate-400 font-medium">Desenvolvido por <span style="color:var(--navy)" class="font-semibold">Parcela Ideal</span></p>
    </div>
  </div>
</div>

<script>
  // ATUALIZADO PARA O NOVO NÚMERO
  const WHATSAPP_NUMBER = '5547992290116'; 
  const INCOME_RATIO = 0.30;

  const incomeInput   = document.getElementById('income');
  const nameInput     = document.getElementById('fullName');
  const whatsappInput = document.getElementById('whatsapp');
  const downInput     = document.getElementById('downPayment');
  const resultEl      = document.getElementById('resultAmount');
  const ctaSection    = document.getElementById('ctaSection');
  const ctaBtn        = document.getElementById('ctaBtn');
  const calcBar       = document.getElementById('calcBar');
  const barWrap       = document.getElementById('barWrap');
  const calcBadge     = document.getElementById('calcBadge');
  const sumIncome     = document.getElementById('summaryIncome');
  const sumDown       = document.getElementById('summaryDown');
  const sumResult     = document.getElementById('summaryResult');

  let calcTimeout = null, currentResult = 0, hasShownCTA = false;

  const fmt = n => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(n);

  function animateNumber(from, to, el, ms = 600) {
    const start = performance.now();
    (function step(now) {
      const p = Math.min((now - start) / ms, 1);
      const e = 1 - Math.pow(1 - p, 3);
      el.textContent = fmt(from + (to - from) * e);
      if (p < 1) requestAnimationFrame(step);
      else {
        el.textContent = fmt(to);
        el.classList.add('pulse-once');
        setTimeout(() => el.classList.remove('pulse-once'), 400);
      }
    })(start);
  }

  function runBar(cb) {
    barWrap.style.display = 'block';
    calcBadge.classList.remove('hidden');
    calcBar.style.width = '0%';
    let w = 0;
    const iv = setInterval(() => { w = Math.min(w + Math.random() * 18 + 8, 85); calcBar.style.width = w + '%'; }, 60);
    setTimeout(() => {
      clearInterval(iv); calcBar.style.width = '100%';
      setTimeout(() => { barWrap.style.display = 'none'; calcBadge.classList.add('hidden'); cb(); }, 220);
    }, 480);
  }

  function recalculate() {
    const income = parseFloat(incomeInput.value) || 0;
    if (income <= 0) {
      resultEl.textContent = '—'; resultEl.style.fontSize = '36px'; resultEl.style.color = '#CBD5E1';
      currentResult = 0; hideCTA(); return;
    }
    const result = income * INCOME_RATIO;
    runBar(() => {
      resultEl.style.color = 'var(--navy)'; resultEl.style.fontSize = '';
      animateNumber(currentResult, result, resultEl);
      currentResult = result; showCTA(income, result);
    });
  }

  incomeInput.addEventListener('input', () => { clearTimeout(calcTimeout); calcTimeout = setTimeout(recalculate, 350); });
  [nameInput, whatsappInput, downInput].forEach(el => el.addEventListener('input', updateLink));

  function showCTA(income, result) {
    const down = parseFloat(downInput.value) || 0;
    sumIncome.textContent = fmt(income);
    sumDown.textContent   = down > 0 ? fmt(down) : '—';
    sumResult.textContent = fmt(result);
    updateLink();
    if (!hasShownCTA) {
      ctaSection.style.display = 'block'; ctaSection.style.opacity = '0';
      ctaSection.classList.remove('hidden-section');
      requestAnimationFrame(() => { ctaSection.style.transition = 'opacity 0.5s ease'; ctaSection.style.opacity = '1'; });
      hasShownCTA = true;
    }
  }

  function hideCTA() {
    if (!hasShownCTA) return;
    ctaSection.style.opacity = '0';
    setTimeout(() => { ctaSection.style.display = 'none'; hasShownCTA = false; }, 400);
  }

  function updateLink() {
    const name   = nameInput.value.trim() || 'Interessado';
    const tel    = whatsappInput.value.trim() || 'Não informado';
    const income = parseFloat(incomeInput.value) || 0;
    const result = income * INCOME_RATIO;
    const down   = parseFloat(downInput.value) || 0;
    
    const msg = [
      '👋 Olá! Acabei de simular minha *Parcela Ideal*.',
      '',
      '📋 *Meus Dados:*',
      `• Nome: ${name}`,
      `• WhatsApp: ${tel}`,
      `• Renda Bruta Mensal: ${fmt(income)}`,
      `• Capacidade de Parcela (30%): ${fmt(result)}`,
      down > 0 ? `• Valor de Entrada: ${fmt(down)}` : null,
      '',
      'Gostaria de agendar uma consultoria para conhecer os imóveis disponíveis! 🏡'
    ].filter(l => l !== null).join('\n');
    
    ctaBtn.href = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(msg)}`;
    sumIncome.textContent = income > 0 ? fmt(income) : '—';
    sumDown.textContent   = down > 0   ? fmt(down)   : '—';
    sumResult.textContent = income > 0 ? fmt(result) : '—';
  }
</script>
</body>
</html>
